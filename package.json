{
  "name": "personal_website",
  "version": "0.1.0-beta",
  "description": "Personal website & blog",
  "bugs": {
    "url": "https://github.com/jheysondev/website/issues"
  },
  "license": "MIT",
  "author": "Jheyson Saavedra",
  "repository": {
    "type": "git",
    "url": "https://github.com/jheysondev/website"
  },
  "scripts": {
    "dev": "vite-ssr dev",
    "build": "vue-tsc --noEmit && vite build",
    "build:force": "vue-tsc --noEmit || true && vite build",
    "serve": "vite preview",
    "format": "prettier --write --ignore-path .gitignore {**,**/**}/*.{vue,ts,json,html,md,scss}",
    "format:check": "prettier --check --ignore-path .gitignore {**,**/**}/*.{vue,ts,json,html,md,scss}",
    "lint": "eslint --ignore-path .gitignore --ext vue,ts,js .",
    "lint:fix": "eslint --ignore-path .gitignore --ext vue,ts,js --fix .",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.36",
    "@fortawesome/free-brands-svg-icons": "^5.15.4",
    "@fortawesome/free-regular-svg-icons": "^5.15.4",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@fortawesome/vue-fontawesome": "^3.0.0-4",
    "vue": "^3.2.2",
    "vue-router": "^4.0.11"
  },
  "devDependencies": {
    "@types/connect": "^3.4.35",
    "@types/node": "^16.4.13",
    "@typescript-eslint/eslint-plugin": "^4.29.1",
    "@typescript-eslint/parser": "^4.29.1",
    "@vitejs/plugin-vue": "^1.4.0",
    "@vue/compiler-sfc": "^3.2.2",
    "@vueuse/head": "^0.6.0",
    "autoprefixer": "^10.3.1",
    "cssnano": "^5.0.7",
    "cssnano-preset-advanced": "^5.1.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-vue": "^7.15.1",
    "husky": "^7.0.1",
    "postcss": "^8.3.6",
    "prettier": "^2.3.2",
    "sass": "^1.37.5",
    "typescript": "^4.3.5",
    "vite": "^2.4.4",
    "vite-ssr": "^0.12.0",
    "vue-eslint-parser": "^7.10.0",
    "vue-tsc": "^0.2.2"
  }
}
